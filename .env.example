# Infobroker — copy to .env and fill in.
# NEVER commit .env (gitignored). This file is safe to commit (empty values only).

# Active broker: paper | alpaca | public | tradier
INFOBROKER_BROKER=paper
INFOBROKER_STARTING_CASH=10000

# Market data: yahoo (default/yfinance) | finnhub | alphavantage | auto
INFOBROKER_DATA_PROVIDER=yahoo
FINNHUB_API_KEY=
ALPHAVANTAGE_API_KEY=

# --- Execution #1 Alpaca ---
ALPACA_API_KEY=
ALPACA_API_SECRET=
ALPACA_PAPER=true

# --- Execution #2 Public (live API — practice in paper first) ---
PUBLIC_PERSONAL_SECRET=
PUBLIC_ACCOUNT_ID=
PUBLIC_API_BASE_URL=https://api.public.com

# --- Execution #3 Tradier ---
TRADIER_ACCESS_TOKEN=
TRADIER_ACCOUNT_ID=
TRADIER_SANDBOX=true

# Web UI (localhost by default)
INFOBROKER_WEB_HOST=127.0.0.1
INFOBROKER_WEB_PORT=8000

# Grapevine assistant (local Ollama)
OLLAMA_HOST=http://127.0.0.1:11434
INFOBROKER_OLLAMA_MODEL=arriella-grapevine:latest
